# Copy to .env and fill in ONE of the provider keys below.
# Provider is auto-detected: GROQ_API_KEY set -> groq, else -> anthropic.
# Override with LLM_PROVIDER=groq|anthropic|openai_compatible

# Free tier, no card needed — get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Paid — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Optional overrides
# TEXT2SQL_MODEL=llama-3.3-70b-versatile   (groq default) | claude-sonnet-5 (anthropic default)
# LLM_BASE_URL=                            (for LLM_PROVIDER=openai_compatible: Gemini/OpenRouter/Ollama endpoints)
# LLM_API_KEY=                             (key for openai_compatible)
TEXT2SQL_DB_PATH=data/warehouse.duckdb
TEXT2SQL_ROW_LIMIT=1000
TEXT2SQL_QUERY_TIMEOUT_S=10
